{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "mention.schema.json",
    "title": "Mention",
    "type": "object",
    "properties": {
        "length": {
            "type": "integer"
        },
        "name": {
            "type": "string"
        },
        "number": {
            "type": "string"
        },
        "start": {
            "type": "integer"
        },
        "uuid": {
            "type": "string"
        }
    },
    "required": [
        "start",
        "length"
    ]
}
